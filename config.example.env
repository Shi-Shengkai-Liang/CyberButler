# ===== Moodle 配置 =====
# Moodle Web Service Token
# 获取方式：登录Moodle → 头像 → Preferences → Security keys → Moodle mobile web service → Reset
MOODLE_TOKEN=your_moodle_token_here

# 你的 Moodle 用户 ID
# 获取方式：登录后点击头像，URL里的 ?id=XXXXX 就是你的ID
MOODLE_USER_ID=your_user_id_here

# 你的学校 Moodle 地址
MOODLE_URL=https://moodle.yourschool.edu

# ===== Gradescope 配置 =====
GRADESCOPE_EMAIL=your_email@school.edu
GRADESCOPE_PASSWORD=your_gradescope_password

# ===== AI 配置 =====
# 选择 AI 提供商：anthropic / gemini / groq
# gemini 和 groq 完全免费
AI_PROVIDER=gemini

# Anthropic API Key（约$1/月）
# 申请：https://console.anthropic.com
ANTHROPIC_API_KEY=

# Google Gemini API Key（免费）
# 申请：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# Groq API Key（免费）
# 申请：https://console.groq.com
GROQ_API_KEY=

# ===== 通知配置 =====
# ntfy.sh 频道名，自己起一个唯一的名字
# 手机下载 ntfy app 后订阅这个频道名
NTFY_TOPIC=your-unique-topic-name

# ===== 网页配置 =====
WEB_PASSWORD=your_web_password
PORT=5000
FLASK_SECRET=change-this-to-a-random-string
